--- !u!1001 &669079893
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 2100328732}
    m_Modifications:
    - target: {fileID: 24748279535260609, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_Name
      value: ItemGuitarraTexto
      objectReference: {fileID: 0}
    - target: {fileID: 24748279535260609, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 3637096645953104953, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_text
      value: "A guitarra portuguesa \xE9 um cordofone com uma caixa de resson\xE2ncia
        em forma de p\xEAra e 12 cordas met\xE1licas. A sua hist\xF3ria remonta \xE0
        Idade M\xE9dia, evoluindo a partir da c\xEDtola. No s\xE9culo XVIII, fundiu-se
        com elementos da guitarra inglesa para ganhar a sua forma atual, tornando-se
        o cora\xE7\xE3o da m\xFAsica portuguesa.\r\nDeriva dos cistres europeus,
        sendo que a guitarra mais antiga do mundo foi constru\xEDda em Lisboa, em
        1581, por Belchior Dias. \n\nInicialmente um instrumento popular em sal\xF5es
        e serenatas, mas a partir de meados do s\xE9culo XIX, consolidou-se como
        o elemento central no acompanhamento do Fado.\n\r\nO instrumento deixou de
        ser apenas de acompanhamento e ganhou um vasto report\xF3rio a solo, tornando-o
        imortalizado.\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 3859437272534295381, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
