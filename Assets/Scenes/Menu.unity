PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 2100328732}
    m_Modifications:
    - target: {fileID: 24748279535260609, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_Name
      value: ItemCalcadaTexto
      objectReference: {fileID: 0}
    - target: {fileID: 24748279535260609, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 3637096645953104953, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_text
      value: "A cal\xE7ada portuguesa \xE9 um dos elementos mais emblem\xE1ticos
        do patrim\xF3nio nacional, um revestimento de piso feito com pequenas pedras
        naturais, geralmente calc\xE1rio branco e basalto preto. \n\r\nSurgiu em
        meados do s\xE9culo XIX, mais concretamente em Lisboa em 1842. O primeiro
        grande projeto e o padr\xE3o mais ic\xF3nico (\"Mar Largo\") foram aplicados
        na Pra\xE7a do Rossio por mestres calceteiros e prisioneiros. \n\nA t\xE9cnica
        funde influ\xEAncias romanas (que j\xE1 pavimentavam estradas) e mouriscas
        (pela vertente ornamental e geom\xE9trica).\r\nColocadas manualmente, os
        diferentes tipos de cal\xE7ada portuguesa formam padr\xF5es e mosaicos decorativos,
        destacando-se pela sua beleza e singularidade \xFAnicas. "
      objectReference: {fileID: 0}
    - target: {fileID: 3859437272534295381, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_Pivot.x
      value: 0.5
      objectReference: {fileID: 0}
    - target: {fileID: 3859437272534295381, guid: 4cb901e10733e7f4d8042cff9820b66d, type: 3}
      propertyPath: m_Pivot.y
